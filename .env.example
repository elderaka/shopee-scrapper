# ── Shopee Credentials ──
SHOPEE_PHONE=08xxxxxxxxxx
SHOPEE_PASSWORD=yourpassword

# ── Server ──
PORT=3000

# ── Headless mode (local only, ignored in remote mode) ──
# Set to "false" to see the browser window
HEADLESS=true

# ── Remote Browser (VPS mode) ──
# Leave empty to run Camoufox locally.
# Set this on the VPS to point to your local browser-server.
# CAMOUFOX_WS_URL=ws://YOUR_LOCAL_IP:4444/camoufox

# ── Browser Server (local machine only) ──
# Port for npm run browser-server
BROWSER_SERVER_PORT=4444
BROWSER_SERVER_PATH=camoufox

# ── Proxy (optional) ──
# PROXY_URL=http://user:pass@host:port

# ── Misc ──
# IP_TEST_URL=http://ipinfo.thordata.com
